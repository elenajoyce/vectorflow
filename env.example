# --- VectorFlow Environment Configuration ---

# Stellar Network Mode (testnet / mainnet)
STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE="Test SGD Network ; September 2015"
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"

# Admin / Deployer configuration
DEPLOYER_SECRET_KEY="S..."

# Contract deployment IDs (leave blank initially, coordinator will auto-load once deployed)
STREAM_ESCROW_CONTRACT_ID="C..."

# Coordinator settings
PORT=4000
DATABASE_URL="file:./vector-flow.db"

# Relayer configuration
RELAYER_SECRET_KEY="S..."
RELAY_POLL_INTERVAL_MS=5000
